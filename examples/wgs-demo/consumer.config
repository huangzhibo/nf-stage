/*
 * 业务运行配置（按项目/客户/环境调整，通过 -c consumer.config 传入）
 */

// 分析参数
params {
    reference = 'hg38'
    input     = 'data/samplesheet.csv'
    bam_input = null  // 从 BAM 开始时设置为 data/bamsheet.csv
}

// 阶段归档（本地测试用相对路径，生产环境改为共享存储如 /shared/archives/wgs-demo）
stage {
    archiveRoot      = '.nf-stage-archive'
    cachedStagesFile = 'cached-stages.tsv'
}
// Tower 平台（按需启用）
// tower {
//     enabled     = true
//     endpoint    = 'https://api.tower.nf'
//     accessToken = '...'
// }
