/*
 * 业务运行配置（按项目/客户/环境调整，通过 -c consumer.config 传入）
 */

// 分析参数
params {
    reference = 'hg38'
    input     = 'samplesheet.csv'
}

// 阶段归档
stage {
    archiveRoot     = '/shared/archives/wgs-demo'
    cachedStagesFile = 'cached-stages.tsv'
}
